# Django core
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_TIME_ZONE=Africa/Kampala

# Local development normally uses config.settings.local through manage.py.
# Tenant/SaaS and production deployment use PostgreSQL through config.settings.tenants/prod.
POSTGRES_DB=edumanage_saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# Public pages
PUBLIC_STATUS_PAGE_ENABLED=True

# Support contact shown in portal footer
SUPPORT_CONTACT_EMAIL=

# Fee reminder delivery: SMS or WHATSAPP
FEE_REMINDER_CHANNEL=SMS
FEE_REMINDER_HANDLER=
FEE_REMINDER_SMS_HANDLER=
FEE_REMINDER_DEFAULT_COUNTRY_CODE=256
FEE_REMINDER_PORTAL_BASE_URL=

# WhatsApp Cloud API
WHATSAPP_CLOUD_ACCESS_TOKEN=
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_VERSION=v20.0
WHATSAPP_CLOUD_TIMEOUT_SECONDS=15
WHATSAPP_STATUS_WEBHOOK_SECRET=

# Receipts and webhooks
FEE_RECEIPT_AUTO_SEND_ON_PAYMENT=False
WEBHOOK_REQUEST_TIMEOUT_SECONDS=8
WEBHOOK_MAX_RETRY_ATTEMPTS=5
WEBHOOK_RETRY_BASE_SECONDS=30
